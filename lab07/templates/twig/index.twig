{% extends 'base.twig' %}

{% block content %}
    {% if flashSuccess %}
        <div class="message success">{{ flashSuccess }}</div>
    {% endif %}

    {% if errors %}
        <div class="message error">Форма содержит ошибки. Исправьте поля и отправьте данные снова.</div>
    {% endif %}

    <section class="section">
        <h2>Добавить транзакцию</h2>
        {% include '_form.twig' %}
    </section>

    <section class="section">
        <h2>Список транзакций</h2>
        {% include '_list.twig' %}
    </section>
{% endblock %}
