<form action="{{ formAction }}" method="post" novalidate>
    <div class="field">
        <label for="transaction_date">Дата транзакции <span class="required">*</span></label>
        <input id="transaction_date" name="transaction_date" type="date" value="{{ oldInput.transaction_date|default('') }}" required>
        {% if errors.transaction_date is defined %}
            <small class="error-text">{{ errors.transaction_date }}</small>
        {% endif %}
    </div>

    <div class="field">
        <label for="amount">Сумма <span class="required">*</span></label>
        <input id="amount" name="amount" type="number" step="0.01" min="0.01" max="1000000" value="{{ oldInput.amount|default('') }}" required>
        {% if errors.amount is defined %}
            <small class="error-text">{{ errors.amount }}</small>
        {% endif %}
    </div>

    <div class="field">
        <label for="merchant">Контрагент <span class="required">*</span></label>
        <input id="merchant" name="merchant" type="text" minlength="2" maxlength="100" value="{{ oldInput.merchant|default('') }}" required>
        {% if errors.merchant is defined %}
            <small class="error-text">{{ errors.merchant }}</small>
        {% endif %}
    </div>

    <div class="field">
        <label for="category">Категория <span class="required">*</span></label>
        <select id="category" name="category" required>
            <option value="">Выберите категорию</option>
            {% for value, label in categories %}
                <option value="{{ value }}" {% if oldInput.category|default('') == value %}selected{% endif %}>{{ label }}</option>
            {% endfor %}
        </select>
        {% if errors.category is defined %}
            <small class="error-text">{{ errors.category }}</small>
        {% endif %}
    </div>

    <fieldset class="field">
        <legend>Тип транзакции <span class="required">*</span></legend>
        {% for value, label in types %}
            <label class="inline-option">
                <input type="radio" name="type" value="{{ value }}" {% if oldInput.type|default('') == value %}checked{% endif %} required>
                {{ label }}
            </label>
        {% endfor %}
        {% if errors.type is defined %}
            <small class="error-text">{{ errors.type }}</small>
        {% endif %}
    </fieldset>

    <div class="field">
        <label for="description">Описание <span class="required">*</span></label>
        <textarea id="description" name="description" rows="5" minlength="10" maxlength="500" required>{{ oldInput.description|default('') }}</textarea>
        {% if errors.description is defined %}
            <small class="error-text">{{ errors.description }}</small>
        {% endif %}
    </div>

    <label class="inline-option">
        <input type="checkbox" name="is_recurring" value="1" {% if oldInput.is_recurring|default('0') == '1' %}checked{% endif %}>
        Повторяющаяся транзакция
    </label>

    <p><button type="submit">Сохранить</button></p>
</form>
